generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  expo_push_token String?
  created_at    DateTime @default(now())

  children Child[]
  tasks    Task[]
  rewards  Reward[]

  @@map("parents")
}

model Child {
  id             String   @id @default(uuid())
  parent_id      String
  name           String
  pin            String
  base_allowance Decimal  @default(0.0) @db.Decimal(10, 2)
  expo_push_token String?
  created_at     DateTime @default(now())

  parent           Parent             @relation(fields: [parent_id], references: [id])
  task_assignments TaskAssignment[]
  redemptions      RewardRedemption[]

  @@map("children")
}

enum TaskType {
  mandatory
  bonus
  penalty
}

enum RecurrenceType {
  daily
  weekly
  monthly
  yearly
}

model Task {
  id          String     @id @default(uuid())
  parent_id   String
  name        String
  description String?
  type        TaskType
  value               Decimal        @db.Decimal(10, 2)
  recurrence_type     RecurrenceType
  recurrence_interval Int            @default(1)
  recurrence_days     Int[]          @default([])
  recurrence_month    Int?
  created_at          DateTime       @default(now())

  parent      Parent           @relation(fields: [parent_id], references: [id])
  assignments TaskAssignment[]
  subtasks    SubTask[]

  @@map("tasks")
}

model TaskAssignment {
  id       String  @id @default(uuid())
  task_id  String
  child_id String
  active   Boolean @default(true)

  task       Task            @relation(fields: [task_id], references: [id])
  child      Child           @relation(fields: [child_id], references: [id])
  executions TaskExecution[]

  @@map("task_assignments")
}

enum ExecutionStatus {
  pending
  completed
  approved
  rejected
}

model TaskExecution {
  id            String          @id @default(uuid())
  assignment_id String
  date          DateTime        @db.Date
  status        ExecutionStatus @default(pending)

  assignment TaskAssignment @relation(fields: [assignment_id], references: [id])
  subtask_completions SubTaskCompletion[]

  @@map("task_executions")
}

model SubTask {
  id      String @id @default(uuid())
  task_id String
  label   String
  order   Int    @default(0)

  task        Task               @relation(fields: [task_id], references: [id], onDelete: Cascade)
  completions SubTaskCompletion[]

  @@map("subtasks")
}

model SubTaskCompletion {
  id           String    @id @default(uuid())
  subtask_id   String
  execution_id String
  checked      Boolean   @default(false)
  checked_at   DateTime?

  subtask   SubTask       @relation(fields: [subtask_id], references: [id], onDelete: Cascade)
  execution TaskExecution @relation(fields: [execution_id], references: [id], onDelete: Cascade)

  @@unique([subtask_id, execution_id])
  @@map("subtask_completions")
}

enum RedemptionStatus {
  pending
  approved
  rejected
}

model Reward {
  id          String   @id @default(uuid())
  parent_id   String
  name        String
  description String?
  cost_in_xp  Int
  max_redeems Int?
  created_at  DateTime @default(now())

  parent      Parent             @relation(fields: [parent_id], references: [id])
  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id         String   @id @default(uuid())
  reward_id  String
  child_id   String
  cost       Int
  status     RedemptionStatus @default(pending)
  created_at DateTime @default(now())

  reward     Reward @relation(fields: [reward_id], references: [id])
  child      Child  @relation(fields: [child_id], references: [id])

  @@map("reward_redemptions")
}

